# 資料庫連線（二擇一，建議優先 DATABASE_URL）
# DATABASE_URL 範例：postgresql+psycopg2://USER:PASS@HOST:PORT/DBNAME
# TEST用於測試須先建立 TEST 資料庫
DATABASE_URL=
TEST_DATABASE_URL=

# 若未設定 DATABASE_URL，則以下組合成連線字串
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres

# 連線池參數（選填）
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_RECYCLE=1800

# OpenAI API 設定（用於聊天推薦與語音辨識功能）
OPENAI_API_KEY=sk-proj-your-api-key-here
OPENAI_MODEL=gpt-4o-mini  # 或使用 gpt-4o, gpt-4-turbo 等
# Whisper API 使用同一個 OPENAI_API_KEY，模型固定為 whisper-1
